# ── Supabase Local (LAN) ──────────────────────────────────────
# Copiaza ca .env si completeaza cu valorile din: supabase status
# IMPORTANT: foloseste IP-ul LAN al masinii (nu 127.0.0.1)
# altfel URL-urile imaginilor stocate in DB nu sunt accesibile de pe telefon.

PUBLIC_SUPABASE_URL=http://192.168.0.126:54321
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX

# ATENTIE: NU adauga SERVICE_ROLE_KEY cu prefix PUBLIC_!
# Cheia service_role bypass-eaza RLS si daca e expusa in browser
# orice atacator iti poate citi/sterge baza de date.
# Daca chiar ai nevoie de service_role, foloseste-o intr-un endpoint
# SvelteKit server-side (+server.ts) cu variabila non-publica:
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXX (fara prefix PUBLIC_)

# Storage
PUBLIC_STORAGE_BUCKET=media
